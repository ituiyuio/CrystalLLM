# CrystaLLM v23 数据准备 .env 模板
# 复制为 .env 后填实际值, 切勿提交 .env

# ModelScope SDK 缓存目录 (避免占满 C 盘)
# MODELSCOPE_CACHE=D:/tmp_v23_dl/

# 临时下载/解压根目录
# TMP_DOWNLOAD_DIR=D:/tmp_v23_dl/

# 下载配额 (chars, 默认 20G code + 10G wiki)
# CODE_QUOTA_CHARS=20000000000
# WIKI_QUOTA_CHARS=10000000000

# 启用 v23 训练模式 (在 train.py 读)
# CRYSTALLM_V23=1
