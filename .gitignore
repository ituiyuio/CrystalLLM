# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
results/
queue/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Experimental code/artifacts
dev/

# Results file
results.tsv

# CrystaLLM bulk data (re-generable from ~/.claude/, too large for git)
crystalllm/data/raw/
crystalllm/data/processed/*.parquet
crystalllm/data/processed/*.bin
crystalllm/data/processed/*.pt
crystalllm/data/

# Training artifacts — model weights and feature caches (all re-generable)
crystalllm/**/*.pt
crystalllm/**/*.npz
crystalllm/**/*.npy
# Root-level training artifacts (same rules, broader scope)
/*.pt
/*.npz
/*.npy

# Local env files (use .env.v23.example as template)
.env
crystalllm/.env
experiments/v49_pre/results/exp17_ckpts/
experiments/v49_pre/results/exp22_ckpts/
experiments/v49_pre/results/exp23_ckpts/
experiments/v49_pre/exp24_ckpts/
